<section class="globisun-home color-{{ section.settings.color_scheme }} gradient">
  <div class="globisun-wrap">
    <div class="globisun-hero">
      <div class="globisun-hero__content">
        <p class="globisun-eyebrow">{{ section.settings.eyebrow }}</p>
        <h1>{{ section.settings.heading }}</h1>
        <p class="globisun-lead">{{ section.settings.subheading }}</p>
        <div class="globisun-actions">
          <a class="button button--primary" href="{{ section.settings.primary_link | default: '/pages/contact' }}">{{ section.settings.primary_label }}</a>
          <a class="button button--secondary" href="{{ section.settings.secondary_link | default: '/collections/all' }}">{{ section.settings.secondary_label }}</a>
        </div>
        <p class="globisun-hero__microcopy">Quote-based support for education programs, studios, creative buyers, and small business purchasing teams.</p>
        <div class="globisun-proofline globisun-proofline--v8" aria-label="B2B purchasing highlights">
          <span>Wholesale intake</span>
          <span>MOQ review</span>
          <span>Bulk pricing request</span>
          <span>Kit planning</span>
          <span>Supplier-fit sourcing</span>
        </div>
      </div>
      <aside class="globisun-hero__panel" aria-label="B2B procurement overview">
        <div class="globisun-panel-card globisun-panel-card--large">
          <span class="globisun-panel-label">Procurement-ready</span>
          <strong>Art supply sourcing for real classrooms, studios, workshops, resale programs, and creative teams.</strong>
        </div>
        <div class="globisun-mini-grid">
          <div class="globisun-panel-card"><span>01</span><strong>Bulk art materials</strong></div>
          <div class="globisun-panel-card"><span>02</span><strong>Program kits</strong></div>
          <div class="globisun-panel-card"><span>03</span><strong>Supplier coordination</strong></div>
          <div class="globisun-panel-card"><span>04</span><strong>Quote-based orders</strong></div>
        </div>
        <div class="globisun-metrics globisun-metrics--v8" aria-label="B2B service signals">
          <div class="globisun-metric"><strong>$500+</strong><span>typical wholesale review point</span></div>
          <div class="globisun-metric"><strong>Quote</strong><span>pricing, package, timing review</span></div>
          <div class="globisun-metric"><strong>CA</strong><span>U.S.-based business presence</span></div>
        </div>
      </aside>
    </div>

    <div class="globisun-section-head">
      <p class="globisun-eyebrow">Who we serve</p>
      <h2>Built for organizations that create, teach, and source art materials.</h2>
      <p>GlobiSun is positioned for buyers who need practical supply planning instead of casual single-item shopping.</p>
    </div>

    <div class="globisun-card-grid globisun-card-grid--four">
      <article class="globisun-card"><span class="globisun-card__label">Education</span><h3>Schools & Programs</h3><p>Classroom materials, workshop supplies, camp kits, and practical art tools for structured learning environments.</p></article>
      <article class="globisun-card"><span class="globisun-card__label">Studio</span><h3>Studios & Workshops</h3><p>Flexible bulk purchasing for private studios, instructors, makerspaces, and recurring creative sessions.</p></article>
      <article class="globisun-card"><span class="globisun-card__label">Resale</span><h3>Retailers & Resellers</h3><p>Product sourcing support for small retailers, e-commerce sellers, and local supply channels.</p></article>
      <article class="globisun-card"><span class="globisun-card__label">Production</span><h3>Creative Teams</h3><p>Supply support for visual development, concept art, media production, design classrooms, and project-based teams.</p></article>
    </div>

    <div class="globisun-band" aria-label="Procurement value points">
      <div class="globisun-band__grid">
        <div class="globisun-band__item"><strong>Bulk-first language</strong><span>Clear MOQ, quote, and sourcing flow.</span></div>
        <div class="globisun-band__item"><strong>Program planning</strong><span>Support for classes, camps, and recurring sessions.</span></div>
        <div class="globisun-band__item"><strong>Product flexibility</strong><span>Catalog items plus custom sourcing review.</span></div>
        <div class="globisun-band__item"><strong>Documentation-ready</strong><span>Cleaner company identity for buyers and suppliers.</span></div>
      </div>
    </div>

    <div class="globisun-split">
      <div>
        <p class="globisun-eyebrow">Wholesale workflow</p>
        <h2>Simple, professional B2B purchasing support.</h2>
        <p>Send us your product category, quantity, target budget, delivery ZIP code, and timeline. We review suitable options and prepare a practical wholesale quote or sourcing recommendation.</p>
        <div class="globisun-resource-strip">
          <a href="/pages/wholesale-policy">Wholesale policy</a>
          <a href="/pages/shipping-lead-time">Shipping & lead time</a>
          <a href="/pages/tax-resale-certificate">Tax & resale info</a>
        </div>
      </div>
      <div class="globisun-steps">
        <div><span>1</span><strong>Send your request</strong><p>Product type, quantity, budget, delivery ZIP code, and target timeline.</p></div>
        <div><span>2</span><strong>Review options</strong><p>We identify suitable products, packaging formats, and supplier availability.</p></div>
        <div><span>3</span><strong>Receive a quote</strong><p>Pricing, lead time, order notes, and fulfillment details are reviewed together.</p></div>
        <div><span>4</span><strong>Confirm & fulfill</strong><p>Once approved, we coordinate processing and delivery based on agreed terms.</p></div>
      </div>
    </div>

    <div class="globisun-section-head">
      <p class="globisun-eyebrow">Core supply categories</p>
      <h2>Start from the catalog, then request bulk pricing or custom combinations.</h2>
    </div>
    <div class="globisun-card-grid globisun-card-grid--three globisun-category-row">
      <a class="globisun-card globisun-card--link" href="/collections/acrylic-paints"><span class="globisun-card__label">Painting</span><h3>Painting Supplies</h3><p>Acrylic paints, brush sets, palettes, and classroom-friendly painting materials.</p></a>
      <a class="globisun-card globisun-card--link" href="/collections/acrylic-markers"><span class="globisun-card__label">Drawing</span><h3>Drawing & Markers</h3><p>Markers, pens, drawing tools, and bulk supplies for daily creative practice.</p></a>
      <a class="globisun-card globisun-card--link" href="/pages/school-studio-kits"><span class="globisun-card__label">Kits</span><h3>School & Studio Kits</h3><p>Product combinations for art classes, workshops, camps, studio programs, and resale sets.</p></a>
    </div>

    <div class="globisun-cta-panel">
      <div>
        <p class="globisun-eyebrow">Wholesale inquiry</p>
        <h2>Need supplies for a class, studio, workshop, or resale project?</h2>
        <p>Tell us what you need. We will help you explore practical B2B supply options and prepare a quote when the request is a fit.</p>
      </div>
      <a class="button button--primary" href="{{ section.settings.primary_link | default: '/pages/contact' }}">{{ section.settings.primary_label }}</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "GlobiSun B2B Home",
  "tag": "section",
  "class": "section globisun-section",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "GlobiSun Art Supply · B2B Wholesale"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "Wholesale Art Supplies for Schools, Studios & Creative Programs"},
    {"type": "textarea", "id": "subheading", "label": "Subheading", "default": "GlobiSun helps art educators, studios, workshop organizers, small retailers, and creative teams source practical, reliable, and cost-conscious art materials for bulk purchasing needs."},
    {"type": "text", "id": "primary_label", "label": "Primary button label", "default": "Request a Wholesale Quote"},
    {"type": "url", "id": "primary_link", "label": "Primary button link"},
    {"type": "text", "id": "secondary_label", "label": "Secondary button label", "default": "Browse Wholesale Catalog"},
    {"type": "url", "id": "secondary_link", "label": "Secondary button link"},
    {"type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1"}
  ],
  "presets": [{"name": "GlobiSun B2B Home"}]
}
{% endschema %}
